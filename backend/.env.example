# DineConnect Backend Environment Configuration
# Copy this file to .env and replace with your actual values

# Server
PORT=8000
NODE_ENV=development

# Database
# Use local MongoDB for development
MONGO_URI=mongodb://127.0.0.1:27017/dineconnect
# For MongoDB Atlas (requires MongoDB Atlas account):
# MONGO_URI=mongodb+srv://username:password@cluster0.mongodb.net/dineconnect?retryWrites=true&w=majority

# JWT Secret (generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))")
JWT_SECRET=replace_me_with_a_random_string_at_least_32_characters_long_xx
JWT_EXPIRES_IN=7d
